---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header'
import Hero from '../components/Hero'
import About from '../components/About'
import Skills from '../components/Skills.astro'
import Contact from '../components/Contact'

import translations from '../i18n/translations'
const en = translations.en
const pt = translations.pt
---

<BaseLayout title="Marcus Ximenes - Software Developer & Tech Leader">
  <Header client:load />
  <main>
    <Hero client:load />
    <About client:load />

    <Skills />

    <!-- Experience Section -->
    <section id="experience" class="border-t-3 border-brutal-border bg-brutal-bg py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16">
          <h2
            class="mb-4 font-sans text-5xl font-titulos uppercase tracking-tighter text-brutal-text md:text-6xl"
            data-i18n="experience.title"
          >
            {en.experience.title}
          </h2>
          <p class="max-w-prose text-lg leading-relaxed text-brutal-text" data-i18n="experience.subtitle">
            {en.experience.subtitle}
          </p>
        </div>

        <div class="space-y-8">
          {en.experience.jobs.map((job, idx) => (
            <div class="rounded-none border-3 border-brutal-border bg-white p-8 dark:bg-stone-900">
              <div class="mb-4 flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                  <h3 class="text-2xl font-titulos uppercase text-brutal-text" data-i18n={`experience.jobs.${idx}.title`}>
                    {job.title}
                  </h3>
                  <p class="font-bold text-brutal-accent">{job.company}</p>
                </div>
                <span class="mt-2 font-bold text-brutal-text md:mt-0" data-i18n={`experience.jobs.${idx}.period`}>
                  {job.period}
                </span>
              </div>
              <p class="leading-relaxed text-brutal-text" data-i18n={`experience.jobs.${idx}.description`}>
                {job.description}
              </p>
            </div>
          ))}

          <!-- Show More Button -->
          <div class="text-center">
            <button
              id="showMoreBtn"
              class="inline-block rounded-none border-3 border-brutal-border bg-transparent px-8 py-4 font-titulos uppercase text-brutal-text transition hover:bg-brutal-accent hover:text-white"
            >
              <span data-i18n="experience.showEarlier">{en.experience.showEarlier}</span>
              <svg
                class="ml-2 inline h-4 w-4 transform transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  strokeWidth="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
          </div>

          <!-- Earlier Experience (Hidden by default) -->
          <div id="earlierExperience" class="hidden space-y-8">
            {en.experience.earlierJobs.map((job, idx) => (
              <div class="rounded-none border-3 border-brutal-border bg-white p-8 dark:bg-stone-900">
                <div class="mb-4 flex flex-col md:flex-row md:items-center md:justify-between">
                  <div>
                    <h3 class="text-2xl font-titulos uppercase text-brutal-text" data-i18n={`experience.earlierJobs.${idx}.title`}>
                      {job.title}
                    </h3>
                    <p class="font-bold text-brutal-accent">{job.company}</p>
                  </div>
                  <span class="mt-2 font-bold text-brutal-text md:mt-0" data-i18n={`experience.earlierJobs.${idx}.period`}>
                    {job.period}
                  </span>
                </div>
                <p class="leading-relaxed text-brutal-text" data-i18n={`experience.earlierJobs.${idx}.description`}>
                  {job.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="border-t-3 border-brutal-border bg-brutal-bg py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16">
          <h2
            class="mb-4 font-sans text-5xl font-titulos uppercase tracking-tighter text-brutal-text md:text-6xl"
            data-i18n="projects.title"
          >
            {en.projects.title}
          </h2>
          <p class="max-w-prose text-lg leading-relaxed text-brutal-text" data-i18n="projects.subtitle">
            {en.projects.subtitle}
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {en.projects.items.map((project, idx) => (
            <div class="rounded-none border-3 border-brutal-border bg-white p-8 dark:bg-stone-900">
              <h3 class="mb-4 text-2xl font-titulos uppercase text-brutal-text" data-i18n={`projects.items.${idx}.title`}>
                {project.title}
              </h3>
              <p class="mb-6 leading-relaxed text-brutal-text" data-i18n={`projects.items.${idx}.description`}>
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="bg-brutal-text px-3 py-1 text-sm font-titulos uppercase text-brutal-bg">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Contact client:load />
  </main>

  <!-- Footer -->
  <footer class="bg-brutal-text py-12 text-brutal-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="border-brutal-bg mb-8 grid grid-cols-1 gap-8 border-b-3 pb-8 md:grid-cols-3">
        <div>
          <h3 class="mb-4 text-2xl font-titulos uppercase tracking-tighter">marcusvinicius.info</h3>
          <p class="leading-relaxed text-brutal-bg" data-i18n="footer.tagline">
            {en.footer.tagline}
          </p>
        </div>

        <div>
          <h4 class="mb-4 text-lg font-titulos uppercase tracking-tight" data-i18n="footer.quickLinks">
            {en.footer.quickLinks}
          </h4>
          <div class="space-y-2">
            <a href="#about" class="block text-brutal-bg transition-colors hover:underline" data-i18n="nav.about">{en.nav.about}</a>
            <a href="#skills" class="block text-brutal-bg transition-colors hover:underline" data-i18n="nav.skills">{en.nav.skills}</a>
            <a href="#experience" class="block text-brutal-bg transition-colors hover:underline" data-i18n="nav.experience">{en.nav.experience}</a>
            <a href="#projects" class="block text-brutal-bg transition-colors hover:underline" data-i18n="nav.projects">{en.nav.projects}</a>
            <a href="#contact" class="block text-brutal-bg transition-colors hover:underline" data-i18n="nav.contact">{en.nav.contact}</a>
          </div>
        </div>

        <div>
          <h4 class="mb-4 text-lg font-titulos uppercase tracking-tight" data-i18n="footer.connect">
            {en.footer.connect}
          </h4>
          <div class="flex space-x-4">
            <a
              href="https://github.com/marcusvinicius"
              class="text-brutal-bg transition-colors hover:underline"
            >
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
            </a>
            <a
              href="https://linkedin.com/in/marcusvx"
              class="text-brutal-bg transition-colors hover:underline"
            >
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
            <a
              href="mailto:marcus@marcusvinicius.info"
              class="text-brutal-bg transition-colors hover:underline"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  strokeWidth="2"
                  d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="pt-8 text-center">
        <p class="text-brutal-bg">
          © {new Date().getFullYear()} Marcus Vinicius Ximenes. <span data-i18n="footer.builtWith">{en.footer.builtWith}</span>
        </p>
      </div>
    </div>
  </footer>

  <script>
    // ─── Show/Hide Earlier Experience ─────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
      const showMoreBtn = document.getElementById('showMoreBtn')
      const earlierExperience = document.getElementById('earlierExperience')
      if (!showMoreBtn || !earlierExperience) return

      const btnTextEl = showMoreBtn.querySelector<HTMLElement>('[data-i18n="experience.showEarlier"]')
      const btnIcon = showMoreBtn.querySelector('svg')

      showMoreBtn.addEventListener('click', function () {
        const isHidden = earlierExperience.classList.contains('hidden')
        const lang = localStorage.getItem('lang') ?? 'en'

        if (isHidden) {
          earlierExperience.classList.remove('hidden')
          if (btnTextEl) btnTextEl.textContent = lang === 'pt' ? 'Ocultar Experiência Anterior' : 'Hide Earlier Experience'
          if (btnIcon) btnIcon.style.transform = 'rotate(180deg)'
        } else {
          earlierExperience.classList.add('hidden')
          if (btnTextEl) btnTextEl.textContent = lang === 'pt' ? 'Mostrar Experiência Anterior' : 'Show Earlier Experience'
          if (btnIcon) btnIcon.style.transform = 'rotate(0deg)'
        }
      })
    })

    // ─── i18n: server-rendered sections ───────────────────────────────────────
    // Build-time data injected as JSON for client-side switching
    const pageI18n: Record<string, Record<string, string>> = {
      'experience.title': { en: 'Professional Experience', pt: 'Experiência Profissional' },
      'experience.subtitle': {
        en: 'A journey through my career highlights and key achievements',
        pt: 'Uma jornada pelos destaques da minha carreira e conquistas principais',
      },
      'experience.showEarlier': { en: 'Show Earlier Experience', pt: 'Mostrar Experiência Anterior' },
      'experience.jobs.0.title': { en: 'Staff Software Engineer', pt: 'Staff Software Engineer' },
      'experience.jobs.0.period': { en: 'May 2024 - Present', pt: 'Mai 2024 - Presente' },
      'experience.jobs.0.description': {
        en: "Leading technical initiatives at one of Brazil's leading HR tech companies, focusing on innovative recruitment solutions.",
        pt: 'Liderança de iniciativas técnicas em uma das principais empresas de HR tech do Brasil, com foco em soluções inovadoras de recrutamento.',
      },
      'experience.jobs.1.title': { en: 'Staff Software Engineer', pt: 'Staff Software Engineer' },
      'experience.jobs.1.period': { en: 'Dec 2023 - May 2024', pt: 'Dez 2023 - Mai 2024' },
      'experience.jobs.1.description': {
        en: 'Implemented microfrontend architecture using React, led Facebook integration rewrite, contributed to Laravel backend optimization, and participated in architectural discussions for modernizing monolithic applications.',
        pt: 'Implementei arquitetura de microfrontend com React, liderei a reescrita da integração com o Facebook, contribuí para a otimização do backend em Laravel e participei de discussões arquiteturais para modernização de aplicações monolíticas.',
      },
      'experience.jobs.2.title': { en: 'Senior Software Engineer', pt: 'Senior Software Engineer' },
      'experience.jobs.2.period': { en: 'Apr 2022 - Present', pt: 'Abr 2022 - Presente' },
      'experience.jobs.2.description': {
        en: 'Technology team member at a startup creating a global online platform and community of women and non-binary photographers collaborating to provide diverse content for brands.',
        pt: 'Membro do time de tecnologia de uma startup criando uma plataforma e comunidade global online de fotógrafas e pessoas não-binárias que colaboram para fornecer conteúdo diversificado para marcas.',
      },
      'experience.jobs.3.title': { en: 'Lead Software Developer/Consultant', pt: 'Lead Software Developer/Consultor' },
      'experience.jobs.3.period': { en: 'Feb 2019 - Apr 2022', pt: 'Fev 2019 - Abr 2022' },
      'experience.jobs.3.description': {
        en: "Led development of digital banking solutions using Kotlin microservices architecture. Provided technical leadership through knowledge sharing, pair programming, and helped resolve technical and organizational challenges. Worked on microfrontend strategies for Brazil's largest cosmetics company.",
        pt: 'Liderei o desenvolvimento de soluções de banking digital usando arquitetura de microsserviços com Kotlin. Proporcionei liderança técnica por meio de compartilhamento de conhecimento, programação em par e ajudei a resolver desafios técnicos e organizacionais. Trabalhei em estratégias de microfrontend para a maior empresa de cosméticos do Brasil.',
      },
      'experience.jobs.4.title': { en: 'Solutions Architect', pt: 'Arquiteto de Soluções' },
      'experience.jobs.4.period': { en: 'Nov 2018 - Feb 2019', pt: 'Nov 2018 - Fev 2019' },
      'experience.jobs.4.description': {
        en: "Solutions Architecture team member at Brazil's largest bank. Authored development guidelines, customized software for client hardware environments, and created migration strategies for architectural updates.",
        pt: 'Membro do time de Arquitetura de Soluções do maior banco do Brasil. Autores de diretrizes de desenvolvimento, customização de softwares para ambientes de hardware de clientes e criação de estratégias de migração para atualizações arquiteturais.',
      },
      'experience.jobs.5.title': { en: 'Software Developer', pt: 'Desenvolvedor de Software' },
      'experience.jobs.5.period': { en: 'Jun 2017 - Nov 2018', pt: 'Jun 2017 - Nov 2018' },
      'experience.jobs.5.description': {
        en: 'Led early development of a labor compliance platform using .NET Core and WebAPI backend, Node.js services for background processing, and cross-platform mobile apps with Ionic.',
        pt: 'Liderei o desenvolvimento inicial de uma plataforma de conformidade trabalhista usando backend com .NET Core e WebAPI, serviços Node.js para processamento em background e apps mobile multiplataforma com Ionic.',
      },
      'experience.earlierJobs.0.title': { en: 'Software Engineer', pt: 'Engenheiro de Software' },
      'experience.earlierJobs.0.period': { en: 'Jun 2016 - Jun 2017', pt: 'Jun 2016 - Jun 2017' },
      'experience.earlierJobs.0.description': {
        en: 'Enhanced code quality and unit testing for various projects in C# and Java. Focused on code refactoring and creating automated and manual unit tests for legacy systems.',
        pt: 'Melhorei a qualidade de código e testes unitários em vários projetos em C# e Java. Foco em refatoração de código e criação de testes automatizados e manuais para sistemas legados.',
      },
      'experience.earlierJobs.1.title': { en: 'Senior Software Developer', pt: 'Desenvolvedor de Software Sênior' },
      'experience.earlierJobs.1.period': { en: 'Sep 2012 - Jun 2016', pt: 'Set 2012 - Jun 2016' },
      'experience.earlierJobs.1.description': {
        en: 'Development team member for a large medical laboratory solution. Responsible for significant performance improvements and providing technical guidance to new team members. Developed complex applications using C#, ASP.Net (WebForms, MVC, Web.API), NHibernate, WCF, and various frontend frameworks.',
        pt: 'Membro do time de desenvolvimento de uma grande solução para laboratórios médicos. Responsável por melhorias significativas de performance e orientação técnica para novos membros da equipe. Desenvolvi aplicações complexas usando C#, ASP.Net (WebForms, MVC, Web.API), NHibernate, WCF e diversos frameworks de frontend.',
      },
      'experience.earlierJobs.2.title': { en: '.NET Developer/Analyst', pt: 'Desenvolvedor/Analista .NET' },
      'experience.earlierJobs.2.period': { en: 'Jan 2011 - Sep 2012', pt: 'Jan 2011 - Set 2012' },
      'experience.earlierJobs.2.description': {
        en: 'Developed and maintained software for managing public schools. Created a tool for generating dynamic reports using ASP.Net and Microsoft Report Definition Language. Played a key role in defining architecture and leading development of a new medical care application.',
        pt: 'Desenvolvi e mantive software para gestão de escolas públicas. Criei uma ferramenta para geração de relatórios dinâmicos com ASP.Net e Microsoft Report Definition Language. Tive papel fundamental na definição da arquitetura e liderança do desenvolvimento de uma nova aplicação de saúde.',
      },
      'experience.earlierJobs.3.title': { en: '.NET Developer/Software Developer', pt: 'Desenvolvedor .NET/Desenvolvedor de Software' },
      'experience.earlierJobs.3.period': { en: 'Jun 2010 - Dec 2010', pt: 'Jun 2010 - Dez 2010' },
      'experience.earlierJobs.3.description': {
        en: 'Outsourced developer for a banking company, focusing on developing integrations between legacy systems and new applications. Development work utilized Service-Oriented Architecture (SOA) with WCF and WPF.',
        pt: 'Desenvolvedor terceirizado para uma empresa bancária, com foco em integrações entre sistemas legados e novas aplicações. O trabalho utilizou Arquitetura Orientada a Serviços (SOA) com WCF e WPF.',
      },
      'experience.earlierJobs.4.title': { en: 'Web Developer/.NET Developer', pt: 'Desenvolvedor Web/Desenvolvedor .NET' },
      'experience.earlierJobs.4.period': { en: '2008 - 2010', pt: '2008 - 2010' },
      'experience.earlierJobs.4.description': {
        en: 'Contributed to a comprehensive human resources platform. Designed and implemented an advanced Full-Text Search solution in SQL Server, greatly improving resume search capabilities. Developed features for large-scale applications using VB.Net, ASP.Net WebForms, and SQL Server.',
        pt: 'Contribuí para uma plataforma completa de recursos humanos. Projetei e implementei uma solução avançada de Full-Text Search no SQL Server, melhorando significativamente a busca de currículos. Desenvolvi funcionalidades para aplicações de grande escala usando VB.Net, ASP.Net WebForms e SQL Server.',
      },
      'experience.earlierJobs.5.title': { en: 'IT Support Analyst', pt: 'Analista de Suporte de TI' },
      'experience.earlierJobs.5.period': { en: 'Jan 2006 - Aug 2008', pt: 'Jan 2006 - Ago 2008' },
      'experience.earlierJobs.5.description': {
        en: 'Provided IT support to internal users, including troubleshooting hardware and software issues on Windows operating systems and performing backup routines. Early career role that established foundation in technology support.',
        pt: 'Forneci suporte de TI a usuários internos, incluindo resolução de problemas de hardware e software em sistemas operacionais Windows e execução de rotinas de backup. Cargo de início de carreira que estabeleceu a base em suporte de tecnologia.',
      },
      'projects.title': { en: 'Featured Projects', pt: 'Projetos em Destaque' },
      'projects.subtitle': {
        en: "Some of the projects I've worked on and personal experiments",
        pt: 'Alguns dos projetos em que trabalhei e experimentos pessoais',
      },
      'projects.items.0.title': { en: 'Digital Banking Platform', pt: 'Plataforma de Banking Digital' },
      'projects.items.0.description': {
        en: 'Scalable microservices architecture for digital banking solutions, focusing on credit card services and backend systems.',
        pt: 'Arquitetura de microsserviços escalável para soluções de banking digital, com foco em serviços de cartão de crédito e sistemas de backend.',
      },
      'projects.items.1.title': { en: 'Creator Platform', pt: 'Plataforma para Criadores' },
      'projects.items.1.description': {
        en: 'Global online platform connecting women and non-binary photographers with brands for diverse content creation.',
        pt: 'Plataforma online global conectando fotógrafas e pessoas não-binárias com marcas para criação de conteúdo diversificado.',
      },
      'projects.items.2.title': { en: 'Labor Compliance Platform', pt: 'Plataforma de Conformidade Trabalhista' },
      'projects.items.2.description': {
        en: 'Platform helping businesses monitor employee breaks and prevent violations, with real-time dashboards and mobile apps.',
        pt: 'Plataforma que auxilia empresas a monitorar intervalos de funcionários e evitar infrações, com dashboards em tempo real e apps mobile.',
      },
      'footer.tagline': {
        en: 'Software Developer & Tech Leader passionate about creating innovative solutions and mentoring the next generation of developers.',
        pt: 'Desenvolvedor de Software e Líder Técnico apaixonado por criar soluções inovadoras e mentorar a próxima geração de desenvolvedores.',
      },
      'footer.quickLinks': { en: 'Quick Links', pt: 'Links Rápidos' },
      'footer.connect': { en: 'Connect', pt: 'Conecte-se' },
      'footer.builtWith': {
        en: 'Built with Astro, React, and Tailwind CSS.',
        pt: 'Feito com Astro, React e Tailwind CSS.',
      },
      'nav.about': { en: 'About', pt: 'Sobre' },
      'nav.skills': { en: 'Skills', pt: 'Skills' },
      'nav.experience': { en: 'Experience', pt: 'Experiência' },
      'nav.projects': { en: 'Projects', pt: 'Projetos' },
      'nav.contact': { en: 'Contact', pt: 'Contato' },
    }

    function applyPageLang(lang: string) {
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n!
        if (pageI18n[key]) {
          el.textContent = pageI18n[key][lang] ?? pageI18n[key]['en']
        }
      })
    }

    // Apply on load
    const initialLang = localStorage.getItem('lang') ?? 'en'
    applyPageLang(initialLang)

    // React to Header toggle
    window.addEventListener('languageChange', (e) => {
      const lang = (e as CustomEvent<string>).detail
      applyPageLang(lang)
    })
  </script>
</BaseLayout>
