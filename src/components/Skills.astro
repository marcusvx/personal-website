---
import { Icon } from 'astro-icon/components'
import translations from '../i18n/translations'

const en = translations.en.skills
const pt = translations.pt.skills
---

<section id="skills" class="border-t-3 border-brutal-border bg-brutal-bg py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h2
        class="mb-4 font-sans text-5xl font-titulos uppercase tracking-tighter text-brutal-text md:text-6xl"
        data-i18n="skills.title"
      >
        {en.title}
      </h2>
      <p class="max-w-prose text-lg leading-relaxed text-brutal-text" data-i18n="skills.subtitle">
        {en.subtitle}
      </p>
      <p class="mt-2 flex items-center gap-2 text-sm text-stone-500" data-i18n="skills.hint">
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {en.hint}
      </p>
    </div>

    {
      en.categories.map((category, catIdx) => (
        <div class="mb-12">
          <h3
            class="mb-6 border-b-4 border-stone-900 pb-2 text-2xl font-black uppercase text-brutal-text dark:border-stone-300"
            data-i18n={`skills.categories.${catIdx}.title`}
          >
            {category.title}
          </h3>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            {category.skills.map((skill, skillIdx) => (
              <div class="skill-card cursor-pointer [perspective:800px]">
                <div class="card-inner relative h-full w-full transition-transform duration-500 [transform-style:preserve-3d]">
                  <!-- Front: icon + name -->
                  <div class="card-face absolute inset-0 flex flex-col items-center justify-center gap-4 border-3 border-stone-900 bg-white p-6 [backface-visibility:hidden] dark:border-stone-300 dark:bg-stone-900">
                    <Icon name={skill.icon} class="h-12 w-12 text-brutal-text" />
                    <span class="text-center text-sm font-bold uppercase tracking-tight text-brutal-text">
                      {skill.name}
                    </span>
                  </div>
                  <!-- Back: description — both languages, toggled by JS -->
                  <div class="card-face absolute inset-0 flex flex-col overflow-hidden border-3 border-stone-900 bg-stone-900 p-4 [backface-visibility:hidden] [transform:rotateY(180deg)]">
                    <span class="mb-2 shrink-0 text-[10px] font-black uppercase tracking-widest text-brutal-accent">
                      {skill.name}
                    </span>
                    <p
                      class="skill-desc-en overflow-y-auto text-xs leading-relaxed text-stone-300"
                      set:html={skill.description}
                    />
                    <p
                      class="skill-desc-pt hidden overflow-y-auto text-xs leading-relaxed text-stone-300"
                      set:html={pt.categories[catIdx].skills[skillIdx].description}
                    />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Min height for flip cards */
  .skill-card {
    min-height: 9rem;
    position: relative;
  }

  .skill-card.flipped {
    z-index: 20;
  }

  .skill-card.flipped .card-inner {
    transform: rotateY(180deg);
  }

  @media (min-width: 768px) {
    .skill-card.flipped .card-inner {
      transform: rotateY(180deg) scale(1.25);
    }
  }

  /* Brutalist shadow on hover (only when not flipped) */
  .skill-card:not(.flipped):hover .card-face:first-child {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #1c1917;
  }
</style>

<script>
  // ─── Flip Cards ───────────────────────────────────────────────────────────
  const allCards = document.querySelectorAll<HTMLElement>('.skill-card')

  allCards.forEach((card) => {
    card.addEventListener('click', () => {
      const isFlipped = card.classList.contains('flipped')
      allCards.forEach((c) => c.classList.remove('flipped'))
      if (!isFlipped) card.classList.add('flipped')
    })
  })

  // ─── i18n: Skills section ─────────────────────────────────────────────────
  const i18nData: Record<string, Record<string, string>> = {
    'skills.title': {
      en: 'Technical Skills',
      pt: 'Habilidades Técnicas',
    },
    'skills.subtitle': {
      en: 'Technologies and tools I work with to bring ideas to life',
      pt: 'Tecnologias e ferramentas que uso para dar vida às ideias',
    },
    'skills.hint': {
      en: 'Click any card to see more details about my experience with the technology.',
      pt: 'Clique em qualquer card para ver mais detalhes sobre minha experiência com a tecnologia.',
    },
    'skills.categories.0.title': { en: 'Languages', pt: 'Linguagens' },
    'skills.categories.1.title': { en: 'Frameworks & APIs', pt: 'Frameworks & APIs' },
    'skills.categories.2.title': { en: 'Infra & Cloud', pt: 'Infra & Cloud' },
    'skills.categories.3.title': { en: 'Architecture & Practices', pt: 'Arquitetura & Práticas' },
  }

  function applySkilLang(lang: string) {
    // Update labelled text nodes
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.dataset.i18n!
      if (i18nData[key]) {
        el.textContent = i18nData[key][lang] ?? i18nData[key]['en']
      }
    })

    // Show/hide skill descriptions
    document.querySelectorAll<HTMLElement>('.skill-desc-en').forEach((el) => {
      el.classList.toggle('hidden', lang === 'pt')
    })
    document.querySelectorAll<HTMLElement>('.skill-desc-pt').forEach((el) => {
      el.classList.toggle('hidden', lang !== 'pt')
    })
  }

  // Apply on load
  const initialLang = localStorage.getItem('lang') ?? 'en'
  applySkilLang(initialLang)

  // React to toggle from Header
  window.addEventListener('languageChange', (e) => {
    const lang = (e as CustomEvent<string>).detail
    applySkilLang(lang)
  })
</script>
